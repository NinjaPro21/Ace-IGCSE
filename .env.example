# Copy to .env.local — values from Firebase Console → Project settings → Your apps (Web).

VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Admin analytics (your Google email — also create Firestore doc admins/{your-uid})
VITE_ADMIN_EMAILS=you@school.edu

# Setup checklist:
# 1. Firebase Console → Authentication → Sign-in method → Enable Google
# 2. Firebase Console → Firestore → Create database
# 3. Authentication → Settings → Authorized domains → add localhost + your hosting URL
#    (include custom domains/subdomains — each hostname must be listed for Google sign-in)
# 4. Deploy: npm run deploy:firebase (rules, indexes, hosting)
#    Live site: https://aceigcse.my
#    Legacy Firebase project ID: project-enlight-notes (infra only — not user-facing branding)
# 5. Firebase Console → Analytics → enable (optional, for product telemetry)
# 6. Admin analytics: set VITE_ADMIN_EMAILS above, then EITHER:
#    a) Firestore → collection `admins` → document ID = your Firebase Auth UID (empty doc OK), OR
#    b) Firestore → collection `config` → document `site` → field adminEmails: ["you@school.edu"]
#    Copy firebase/config.site.example.json as a template. Deploy rules after changes.
# 7. Reset pilot data (profiles + schools + platform stats):
#    Firebase Console → Service accounts → Generate key → then:
#    $env:GOOGLE_APPLICATION_CREDENTIALS="C:\path\to\key.json"
#    npm run firebase:reset
