# Copy to .env.local — values from Firebase Console → Project settings → Your apps (Web).

VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Setup checklist:
# 1. Firebase Console → Authentication → Sign-in method → Enable Google
# 2. Firebase Console → Firestore → Create database
# 3. Authentication → Settings → Authorized domains → add localhost + your hosting URL
# 4. Deploy: npm run deploy:firebase (rules, indexes, hosting)
# 5. Firebase Console → Analytics → enable (optional, for product telemetry)
