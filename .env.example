# Copy to .env.local — values from Firebase Console → Project settings → Your apps (Web).

VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Web push (Firebase Console → Cloud Messaging → Web Push certificates)
VITE_FIREBASE_VAPID_KEY=your-vapid-public-key

# Admin analytics UI — comma-separated Google emails baked into the client build.
# Must match the account you sign in with. ALSO create admins/{uid} (see checklist #6).
VITE_ADMIN_EMAILS=you@school.edu

# Optional product analytics (PostHog stub in trackEvent — no-op until key is set)
# VITE_PUBLIC_POSTHOG_KEY=
# VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Optional hash salt for events collection userIdHash
# VITE_EVENT_HASH_SALT=enlight-events

# --- Vercel Cron (server-only; do NOT prefix with VITE_) ---
# Nightly rollup writes platformStats/summary + daily/weekly via Admin SDK.
# CRON_SECRET=generate-a-long-random-string
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Setup checklist:
# 1. Firebase Console → Authentication → Sign-in method → Enable Google
# 2. Firebase Console → Firestore → Create database
# 3. Authentication → Settings → Authorized domains → add localhost + your hosting URL
#    (include custom domains/subdomains — each hostname must be listed for Google sign-in)
# 4. Deploy: npm run deploy:firebase (rules, indexes, hosting)
#    Live site: https://aceigcse.my
#    Legacy Firebase project ID: project-enlight-notes (infra only — not user-facing branding)
# 5. Firebase Console → Analytics → enable (optional, for product telemetry)
# 6. Admin analytics (you need BOTH UI + rules):
#    a) UI: set VITE_ADMIN_EMAILS above AND/OR create Firestore doc
#       Collection `admins` → Document ID = your Auth UID (Authentication → Users → copy UID).
#       Empty document fields are fine. Without this (or VITE_ADMIN_EMAILS at build time),
#       the Analytics nav tab will not appear.
#    b) Rules: Firestore → `config/site` → adminEmails: ["you@school.edu"]
#       (not client-readable; used by security rules only — does NOT show the Analytics tab)
#    Copy firebase/config.site.example.json as a template. Deploy rules after changes.
# 7. Privacy: signed-in users can view social profile cards (friend requests, etc.).
#    Quiz/study detail + email live under profiles/{uid}/private/secure (owner + admin only).
# 7. Reset pilot data (profiles + schools + platform stats):
#    Firebase Console → Service accounts → Generate key → then:
#    $env:GOOGLE_APPLICATION_CREDENTIALS="C:\path\to\key.json"
#    npm run firebase:reset
