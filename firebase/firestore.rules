rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function siteConfig() {
      return exists(/databases/$(database)/documents/config/site)
        ? get(/databases/$(database)/documents/config/site).data
        : null;
    }

    function isAdmin() {
      return signedIn()
        && (
          exists(/databases/$(database)/documents/admins/$(request.auth.uid))
          || (
            siteConfig() != null
            && request.auth.token.email != null
            && request.auth.token.email in siteConfig().adminEmails
          )
        );
    }

    function myProfile() {
      return exists(/databases/$(database)/documents/profiles/$(request.auth.uid))
        ? get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data
        : null;
    }

    function mySchoolId() {
      return myProfile() != null && myProfile().schoolId != null ? myProfile().schoolId : null;
    }

    function isFriend(userId) {
      return signedIn()
        && myProfile() != null
        && myProfile().friendIds != null
        && myProfile().friendIds.hasAny([userId]);
    }

    function targetProfile(userId) {
      return exists(/databases/$(database)/documents/profiles/$(userId))
        ? get(/databases/$(database)/documents/profiles/$(userId)).data
        : null;
    }

    function sharesSchoolWithUser(userId) {
      return signedIn()
        && mySchoolId() != null
        && targetProfile(userId) != null
        && targetProfile(userId).schoolId == mySchoolId();
    }

    function sharesClanWithUser(userId) {
      return signedIn()
        && myProfile() != null
        && myProfile().clanIds != null
        && targetProfile(userId) != null
        && targetProfile(userId).clanIds != null
        && targetProfile(userId).clanIds.hasAny(myProfile().clanIds);
    }

    function profileFriendIds() {
      return resource.data.get('friendIds', []);
    }

    function incomingFriendIds() {
      return request.resource.data.get('friendIds', []);
    }

    function canSyncFriendIdsOnOtherProfile() {
      let oldIds = profileFriendIds();
      let newIds = incomingFriendIds();
      return signedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['friendIds'])
        && (
          (newIds.hasAll(oldIds)
            && newIds.size() == oldIds.size() + 1
            && request.auth.uid in newIds
            && !(request.auth.uid in oldIds))
          || (oldIds.hasAll(newIds)
            && oldIds.size() == newIds.size() + 1
            && request.auth.uid in oldIds
            && !(request.auth.uid in newIds))
        );
    }

    function validInitialProfile() {
      let d = request.resource.data;
      return (!('xp' in d) || (d.xp is int && d.xp >= 0 && d.xp <= 5000))
        && (!('streakDays' in d) || (d.streakDays is int && d.streakDays >= 0 && d.streakDays <= 30))
        && (!('longestStreak' in d) || (d.longestStreak is int && d.longestStreak >= 0 && d.longestStreak <= 30))
        && !('email' in d)
        && !('progress' in d);
    }

    function validProfileUpdate() {
      let old = resource.data;
      let neu = request.resource.data;
      let oldXp = old.get('xp', 0);
      let newXp = neu.get('xp', 0);
      let oldStreak = old.get('streakDays', 0);
      let newStreak = neu.get('streakDays', 0);
      let oldLongest = old.get('longestStreak', 0);
      let newLongest = neu.get('longestStreak', 0);
      let oldAch = old.get('achievementIds', []);
      let newAch = neu.get('achievementIds', []);
      return newXp is int && newXp >= 0 && newXp <= 50000
        && newXp <= oldXp + 300
        && newStreak is int && newStreak >= 0 && newStreak <= 366
        && newStreak <= oldStreak + 1
        && newLongest is int && newLongest >= oldLongest && newLongest <= 366
        && newAch.size() <= oldAch.size() + 3
        // Study detail must live under profiles/{uid}/private — never on the social card.
        && !('progress' in neu);
    }

    function validLeaderboardEntry() {
      let neu = request.resource.data;
      return neu.displayName is string
        && neu.xp is int && neu.xp >= 0 && neu.xp <= 50000
        && neu.streakDays is int && neu.streakDays >= 0 && neu.streakDays <= 366
        && neu.longestStreak is int && neu.longestStreak >= 0 && neu.longestStreak <= 366
        && validLeaderboardPeriodScores();
    }

    // Denormalized day/week/month scores must be internally consistent.
    function validLeaderboardPeriodScores() {
      let neu = request.resource.data;
      return neu.get('dayXp', 0) is int && neu.get('dayXp', 0) >= 0
        && neu.get('weekXp', 0) is int && neu.get('weekXp', 0) >= 0
        && neu.get('monthXp', 0) is int && neu.get('monthXp', 0) >= 0 && neu.get('monthXp', 0) <= 50000
        && neu.get('dayXp', 0) <= neu.get('weekXp', 0)
        && neu.get('weekXp', 0) <= neu.get('monthXp', 0);
    }

    // Updates must grow gradually (mirrors validProfileUpdate) or match the
    // delta-capped profile doc — a client can no longer jump straight to the
    // top of the board with one write.
    function validLeaderboardUpdate() {
      let old = resource.data;
      let neu = request.resource.data;
      let p = myProfile();
      let pXp = p != null ? p.get('xp', 0) : 0;
      let pStreak = p != null ? p.get('streakDays', 0) : 0;
      return validLeaderboardEntry()
        && (neu.xp <= old.get('xp', 0) + 300 || neu.xp <= pXp)
        && (neu.streakDays <= old.get('streakDays', 0) + 1 || neu.streakDays <= pStreak)
        && neu.longestStreak >= old.get('longestStreak', 0);
    }

    function isBuddyStreakMember() {
      return resource.data.uidA == request.auth.uid || resource.data.uidB == request.auth.uid;
    }

    function isCreatingBuddyStreak() {
      return request.resource.data.uidA == request.auth.uid
        || request.resource.data.uidB == request.auth.uid;
    }

    function isJoiningStudyRoom() {
      let oldMembers = resource.data.get('memberUids', []);
      let newMembers = request.resource.data.get('memberUids', []);
      return !(request.auth.uid in oldMembers)
        && request.auth.uid in newMembers
        && newMembers.size() == oldMembers.size() + 1
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberUids']);
    }

    function isLeavingStudyRoom() {
      let oldMembers = resource.data.get('memberUids', []);
      let newMembers = request.resource.data.get('memberUids', []);
      return request.auth.uid in oldMembers
        && !(request.auth.uid in newMembers)
        && newMembers.size() == oldMembers.size() - 1
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberUids']);
    }

    function isMemberCountAdjust(delta) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberCount'])
        && request.resource.data.memberCount is int
        && request.resource.data.memberCount == resource.data.get('memberCount', 0) + delta
        && request.resource.data.memberCount >= 0;
    }

    function friendRequestRespond() {
      return resource.data.toUid == request.auth.uid
        && resource.data.status == 'pending'
        && request.resource.data.status in ['accepted', 'declined']
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);
    }

    function validBuddyStreakCreate() {
      let neu = request.resource.data;
      return neu.streakDays == 1
        && neu.lastBothActiveDate is string
        && neu.uidA is string
        && neu.uidB is string;
    }

    function validBuddyStreakUpdate() {
      let old = resource.data;
      let neu = request.resource.data;
      let affected = neu.diff(old).affectedKeys();
      return neu.streakDays is int
        && neu.streakDays >= 1
        && neu.streakDays <= 366
        && neu.lastBothActiveDate is string
        && (neu.streakDays == old.streakDays || neu.streakDays == old.streakDays + 1 || neu.streakDays == 1)
        && affected.hasOnly(['streakDays', 'lastBothActiveDate', 'updatedAt']);
    }

    function validPushDoc() {
      let neu = request.resource.data;
      return neu.keys().hasOnly(['fcmToken', 'enabled', 'updatedAt', 'lastStreakReminderDate'])
        && (!('fcmToken' in neu) || neu.fcmToken is string)
        && (!('enabled' in neu) || neu.enabled is bool)
        && (!('lastStreakReminderDate' in neu) || neu.lastStreakReminderDate is string);
    }

    match /admins/{userId} {
      // Existence check for own doc only — never listable.
      allow get: if signedIn() && request.auth.uid == userId;
      allow list: if false;
      allow write: if false;
    }

    // Admin email list is server-side only (rules get() still works for isAdmin).
    match /config/site {
      allow read, write: if false;
    }

    match /profiles/{userId} {
      // Social card only — any signed-in user (friend requests OK). Secrets are under /private.
      allow read: if signedIn();
      allow create: if isOwner(userId) && validInitialProfile();
      allow update: if (isOwner(userId) && validProfileUpdate()) || canSyncFriendIdsOnOtherProfile();
      allow delete: if false;

      // Email + full study/quiz progress — owner or admin only.
      match /private/{docId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create, update: if isOwner(userId)
          && (docId != 'push' || validPushDoc());
        allow delete: if false;
      }

      // Per-user learning analytics for research rollups — owner write; other users cannot read.
      match /analytics/{docId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create, update: if isOwner(userId) && docId == 'learning';
        allow delete: if false;
      }
    }

    // Creates are anchored to the (delta-capped) profile so delete+recreate
    // can't bypass the update caps.
    function validLeaderboardCreate() {
      let p = myProfile();
      let pXp = p != null ? p.get('xp', 0) : 0;
      return validLeaderboardEntry() && request.resource.data.xp <= pXp + 300;
    }

    match /leaderboard/{userId} {
      allow read: if signedIn();
      allow create: if isOwner(userId) && validLeaderboardCreate();
      allow update: if isOwner(userId) && validLeaderboardUpdate();
      allow delete: if isOwner(userId);
    }

    // Know the code → getDoc works; listing every code is blocked.
    match /friendCodes/{code} {
      allow get: if signedIn();
      allow list: if false;
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && !exists(/databases/$(database)/documents/friendCodes/$(code));
      // Only the current owner may update — otherwise anyone could point an
      // existing code at their own account and hijack friend invites.
      allow update: if signedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
      allow delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    match /schools/{schoolId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.inviteCode is string
        && request.resource.data.name is string
        && request.resource.data.type in ['school', 'clan']
        && request.resource.data.get('memberCount', 1) == 1;
      // Denormalized memberCount — join/leave bumps only; metadata is immutable.
      allow update: if signedIn() && (isMemberCountAdjust(1) || isMemberCountAdjust(-1));
      allow delete: if false;
    }

    match /platformStats/summary {
      allow read: if isAdmin();
      allow write: if false;

      match /daily/{dayId} {
        allow read: if isAdmin();
        allow write: if false;
      }
      match /weekly/{weekId} {
        allow read: if isAdmin();
        allow write: if false;
      }
    }

    match /friendRequests/{requestId} {
      allow read: if signedIn()
        && (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid);
      allow create: if signedIn() && request.resource.data.fromUid == request.auth.uid;
      allow update: if signedIn() && friendRequestRespond();
    }

    match /presence/{userId} {
      allow read: if signedIn()
        && (
          isOwner(userId)
          || isFriend(userId)
          || sharesSchoolWithUser(userId)
          || sharesClanWithUser(userId)
        );
      allow write: if isOwner(userId);
    }

    match /studyRooms/{roomId} {
      // Join-by-link uses getDoc(roomId); listing every room is blocked.
      allow get: if signedIn();
      allow list: if false;
      allow create: if signedIn() && request.resource.data.createdBy == request.auth.uid;
      // The only legal update is adding/removing yourself from memberUids —
      // room metadata (topic, creator, startedAt) is immutable after create.
      allow update: if signedIn() && (isJoiningStudyRoom() || isLeavingStudyRoom());
    }

    match /buddyStreaks/{pairId} {
      allow read: if signedIn() && isBuddyStreakMember();
      allow create: if signedIn() && isCreatingBuddyStreak() && validBuddyStreakCreate();
      allow update: if signedIn() && isBuddyStreakMember() && validBuddyStreakUpdate();
    }

    // Opponent accepts/declines a pending duel — status is the only change.
    function duelRespondUpdate() {
      return resource.data.opponentUid == request.auth.uid
        && resource.data.status == 'pending'
        && request.resource.data.status in ['active', 'declined']
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);
    }

    // A participant submits their own score exactly once. Completing the
    // duel (status + winnerUid) is only allowed together with the second
    // score, and the winner must be one of the two participants.
    function duelChallengerScoreUpdate() {
      let old = resource.data;
      let neu = request.resource.data;
      let affected = neu.diff(old).affectedKeys();
      return old.challengerUid == request.auth.uid
        && old.status == 'active'
        && !('challengerScore' in old)
        && neu.challengerScore is number
        && neu.challengerTimeSec is number
        && (
          affected.hasOnly(['challengerScore', 'challengerTimeSec'])
          || (
            affected.hasOnly(['challengerScore', 'challengerTimeSec', 'status', 'winnerUid'])
            && 'opponentScore' in old
            && neu.status == 'complete'
            && neu.winnerUid in [old.challengerUid, old.opponentUid]
          )
        );
    }

    function duelOpponentScoreUpdate() {
      let old = resource.data;
      let neu = request.resource.data;
      let affected = neu.diff(old).affectedKeys();
      return old.opponentUid == request.auth.uid
        && old.status == 'active'
        && !('opponentScore' in old)
        && neu.opponentScore is number
        && neu.opponentTimeSec is number
        && (
          affected.hasOnly(['opponentScore', 'opponentTimeSec'])
          || (
            affected.hasOnly(['opponentScore', 'opponentTimeSec', 'status', 'winnerUid'])
            && 'challengerScore' in old
            && neu.status == 'complete'
            && neu.winnerUid in [old.challengerUid, old.opponentUid]
          )
        );
    }

    match /duels/{duelId} {
      allow read: if signedIn()
        && (resource.data.challengerUid == request.auth.uid
          || resource.data.opponentUid == request.auth.uid);
      allow create: if signedIn()
        && request.resource.data.challengerUid == request.auth.uid
        && request.resource.data.opponentUid is string
        && request.resource.data.opponentUid != request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.difficulty in ['easy', 'medium', 'hard', 'pyp'];
      // Participants can no longer overwrite each other's scores or flip
      // winnerUid arbitrarily.
      allow update: if signedIn()
        && (duelRespondUpdate() || duelChallengerScoreUpdate() || duelOpponentScoreUpdate());
    }

    match /events/{eventId} {
      allow read: if isAdmin();
      allow create: if signedIn()
        && request.resource.data.authUid == request.auth.uid
        && request.resource.data.event is string
        && request.resource.data.userIdHash is string
        && request.resource.data.timestamp is string
        && !('uid' in request.resource.data);
      allow update, delete: if false;
    }

    match /appReviews/{reviewId} {
      allow read: if isAdmin();
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && request.resource.data.comment is string
        && request.resource.data.comment.size() <= 500;
      allow update, delete: if false;
    }

    // Deny anything else (no open collections).
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
